LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4-mini
LLM_TEMPERATURE=0.5

# 单端点：
# MCP_SERVER_ENDPOINTS=http://localhost:9000/mcp
# 多端点：
# MCP_SERVER_ENDPOINTS=http://localhost:9000/mcp,http://localhost:9100/mcp
# MCP 首次连接失败后的重试间隔（秒）
# MCP_CONNECT_RETRY_SECONDS=2.0

# CLI_SERVER_HOST=localhost
# CLI_SERVER_PORT=9000
# CLI_SERVER_CHANNEL_NAME=cli
