MODEL_NAME=gpt-4.1-mini
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
MCP_GATEWAY_SERVERS=playwright,fetch,time
MCP_GATEWAY_AUTH_TOKEN=your_fixed_gateway_bearer_token
LOG_LEVEL=info

QQ_ADAPTER_LOG_LEVEL=info
DOWNSTREAM_WS_URL=ws://hub-service:8100/qq/events
DOWNSTREAM_WS_TOKEN=
DOWNSTREAM_WS_OPEN_TIMEOUT_SECONDS=5
DOWNSTREAM_WS_RECONNECT_INTERVAL_SECONDS=3
ONEBOT_WS_ACTION_TIMEOUT_SECONDS=5

HUB_LOG_LEVEL=info
HUB_AGENT_SERVICE_URL=http://agent-service:8000
HUB_QQ_ADAPTER_API_URL=http://qq-adapter-service:8010
HUB_AGENT_MAX_TURNS=10
HUB_HTTP_TIMEOUT_SECONDS=5
